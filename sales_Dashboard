<%{
	%>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sales Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --blue:#1E88E5;
    --blue-dark:#1565C0;
    --blue-soft:#E8F2FD;
    --teal:#089BAB;
    --teal-soft:#E1F3F5;
    --green:#2FA35A;
    --green-soft:#E5F5EA;
    --orange:#F0932B;
    --orange-soft:#FDEEDF;
    --red:#E5504A;
    --red-soft:#FCE7E6;
    --purple:#7C5CBF;
    --purple-soft:#EFE9FA;
    --indigo:#5B6EE8;
    --indigo-soft:#E9EBFC;
    --grey:#B0B7C0;
    --grey-soft:#EEF0F3;

    --sidebar-w:64px;
    --bg:#F4F6F8;
    --surface:#FFFFFF;
    --ink:#23272E;
    --ink-soft:#6B7280;
    --ink-faint:#9AA1AC;
    --line:#E4E7EB;
    --radius:8px;
    --shadow:0 1px 3px rgba(16,24,40,0.06), 0 1px 2px rgba(16,24,40,0.04);
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    font-family:'Inter','Roboto',Arial,sans-serif;
    background:var(--bg);
    color:var(--ink);
    font-size:14px;
  }
  a{text-decoration:none;color:inherit;}

  /* ===================== LAYOUT ===================== */
  .app{display:flex;min-height:100vh;}

  /* ---------- SIDEBAR ---------- */
  .sidebar{
    width:var(--sidebar-w);
    background:#FFFFFF;
    border-right:1px solid var(--line);
    display:flex;
    flex-direction:column;
    align-items:center;
    padding:16px 0;
    flex:none;
  }
  .sidebar .logo{
    width:34px;height:34px;
    border-radius:8px;
    background:var(--blue);
    color:#fff;
    display:flex;align-items:center;justify-content:center;
    font-weight:700;
    font-size:14px;
    margin-bottom:28px;
  }
  .sidebar nav{display:flex;flex-direction:column;gap:6px;width:100%;align-items:center;}
  .sidebar .nav-item{
    width:40px;height:40px;
    border-radius:8px;
    display:flex;align-items:center;justify-content:center;
    color:var(--ink-faint);
    cursor:pointer;
  }
  .sidebar .nav-item svg{width:19px;height:19px;}
  .sidebar .nav-item.active{background:var(--blue-soft);color:var(--blue);}
  .sidebar .nav-item:hover:not(.active){background:var(--grey-soft);color:var(--ink-soft);}
  .sidebar .nav-spacer{flex:1;}
  .sidebar .nav-bottom{margin-top:auto;display:flex;flex-direction:column;gap:6px;align-items:center;}
  .sidebar .nav-item.danger:hover{background:var(--red-soft);color:var(--red);}

  /* ---------- MAIN ---------- */
  .main{flex:1;min-width:0;display:flex;flex-direction:column;}

  /* ---------- TOPBAR ---------- */
  .topbar{
    background:#fff;
    border-bottom:1px solid var(--line);
    padding:0 28px;
    height:60px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:10px;
  }
  .topbar-title h1{font-size:17px;font-weight:700;margin:0;color:var(--ink);}
  .breadcrumb{font-size:12.5px;color:var(--ink-faint);font-weight:500;}
  .topbar-actions{display:flex;align-items:center;gap:14px;}
  .icon-btn{
    width:34px;height:34px;border-radius:8px;
    display:flex;align-items:center;justify-content:center;
    color:var(--ink-faint);cursor:pointer;
  }
  .icon-btn:hover{background:var(--grey-soft);color:var(--ink-soft);}
  .icon-btn svg{width:18px;height:18px;}
  .icon-btn.has-dot{position:relative;}
  .icon-btn.has-dot::after{
    content:'';position:absolute;top:6px;right:6px;
    width:6px;height:6px;border-radius:50%;background:var(--red);
    border:1.5px solid #fff;
  }
  .avatar{
    width:32px;height:32px;border-radius:50%;
    background:var(--orange);color:#fff;
    font-size:12.5px;font-weight:700;
    display:flex;align-items:center;justify-content:center;
  }
  .live-badge{
    display:flex;align-items:center;gap:6px;
    font-size:11.5px;font-weight:700;color:var(--green);
    background:var(--green-soft);padding:5px 10px 5px 8px;
    border-radius:999px;letter-spacing:.03em;
  }
  .live-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 1.8s infinite;}
  @keyframes pulse{
    0%{box-shadow:0 0 0 0 rgba(47,163,90,.5);}
    70%{box-shadow:0 0 0 6px rgba(47,163,90,0);}
    100%{box-shadow:0 0 0 0 rgba(47,163,90,0);}
  }

  /* ---------- CONTENT ---------- */
  .content{padding:24px 28px 40px;max-width:1480px;width:100%;margin:0 auto;}
  .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:18px;}
  .col-12{grid-column:span 12;}
  .col-8{grid-column:span 8;}
  .col-4{grid-column:span 4;}
  .col-3{grid-column:span 3;}

  /* ---------- KPI CARDS ---------- */
  .kpi-card{
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:var(--radius);
    box-shadow:var(--shadow);
    padding:16px 18px;
    display:flex;
    align-items:center;
    gap:14px;
  }
  .kpi-icon{width:42px;height:42px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex:none;}
  .kpi-icon svg{width:20px;height:20px;}
  .kpi-text{min-width:0;}
  .kpi-value{font-size:22px;font-weight:700;line-height:1.1;color:var(--ink);white-space:nowrap;}
  .kpi-label{font-size:12.5px;color:var(--ink-soft);font-weight:500;margin-top:2px;white-space:nowrap;}

  /* ---------- WIDGET CARD ---------- */
  .widget{
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:var(--radius);
    box-shadow:var(--shadow);
    padding:18px 20px 20px;
  }
  .widget-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
  .widget-head-left{display:flex;align-items:center;gap:9px;}
  .widget-icon{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex:none;}
  .widget-icon svg{width:15px;height:15px;}
  .widget-title{font-size:14.5px;font-weight:700;color:var(--ink);}
  .widget-subtitle{font-size:11.5px;color:var(--ink-faint);font-weight:500;margin-top:1px;}
  .kebab{color:var(--ink-faint);cursor:pointer;padding:4px;}
  .kebab svg{width:16px;height:16px;display:block;}
  .divider{height:1px;background:var(--line);margin:0 0 16px;}
  .badge{font-size:11px;font-weight:700;padding:4px 10px;border-radius:5px;white-space:nowrap;}
  select.period{
    font-size:12.5px;font-weight:600;color:var(--ink-soft);
    border:1px solid var(--line);background:var(--grey-soft);
    border-radius:999px;padding:6px 12px;
  }

  /* ---------- PIPELINE BAR CHART (pill bars) ---------- */
  .trend-chart{display:flex;align-items:flex-end;justify-content:space-around;gap:10px;height:170px;padding:0 4px;}
  .trend-col{display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:100%;flex:1;}
  .trend-bar-wrap{flex:1;display:flex;align-items:flex-end;justify-content:center;width:100%;}
  .trend-bar{width:14px;border-radius:20px;background:var(--grey-soft);transition:height .6s cubic-bezier(.17,.67,.83,.67);}
  .trend-val{font-size:11px;font-weight:700;color:var(--ink);margin-bottom:6px;}
  .trend-label{margin-top:12px;font-size:10.5px;font-weight:700;color:var(--ink-faint);text-transform:uppercase;letter-spacing:.03em;}

  /* ---------- INSIGHTS PANEL ---------- */
  .insight-block{margin-bottom:18px;}
  .insight-block:last-child{margin-bottom:0;}
  .insight-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:8px;}
  .insight-top .l{font-size:12.5px;font-weight:600;color:var(--ink-soft);}
  .insight-top .v{font-size:20px;font-weight:700;color:var(--ink);}
  .progress-big{height:10px;background:var(--grey-soft);border-radius:6px;overflow:hidden;}
  .progress-big-fill{height:100%;border-radius:6px;}
  .insight-note{font-size:11.5px;color:var(--ink-faint);font-weight:500;margin-top:7px;}

  /* ---------- TABLE ---------- */
  table.data-table{width:100%;border-collapse:collapse;}
  table.data-table thead th{
    text-align:left;font-size:11px;font-weight:700;color:var(--ink-faint);
    text-transform:uppercase;letter-spacing:.03em;padding:0 10px 10px 0;
    border-bottom:1px solid var(--line);
  }
  table.data-table thead th.num{text-align:right;}
  table.data-table tbody td{
    padding:14px 10px 14px 0;border-bottom:1px solid var(--line);
    font-size:13.5px;color:var(--ink);vertical-align:middle;
  }
  table.data-table tbody tr:last-child td{border-bottom:none;}
  table.data-table td.stage-name{display:flex;align-items:center;gap:12px;font-weight:600;}
  table.data-table td.value{text-align:right;font-weight:700;font-size:16px;}
  .stage-icon{
    width:36px;height:36px;border-radius:9px;
    display:flex;align-items:center;justify-content:center;
    flex:none;color:#fff;
  }
  .stage-icon svg{width:17px;height:17px;}

  @media (max-width:1100px){
    .col-8,.col-4,.col-3{grid-column:span 12;}
  }
  @media (max-width:640px){
    .content{padding:18px;}
    .trend-chart{gap:4px;}
  }
</style>
</head>
<body>
<div class="app">

<%
		leadCount = All_Enquiries[ID != null].count();
		contactCount = Contact[ID != null].count();
		accountCount = Account[ID != null].count();
		deals = Bookings[ID != null].count();
		risedQuotes = Quotation[ID != null].count();
		approvedQuotes = Quotation[Status == "Approved"].count();
		rentalPurchase = Rental_Purchase_Order[ID != null].count();
	%>

  <!-- ===================== MAIN ===================== -->
  <div class="main">


    <!-- CONTENT -->
    <div class="content">
      <div class="grid">

        <!-- ===== KPI ROW 1 ===== -->
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--blue-soft);color:var(--blue);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="3.5"/><path d="M5 20c0-3.5 3-6 7-6s7 2.5 7 6"/></svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-value"><%=leadCount%></div>
            <div class="kpi-label">Total Leads</div>
          </div>
        </div>
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--indigo-soft);color:var(--indigo);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 20v-2a4 4 0 00-4-4H7a4 4 0 00-4 4v2"/><circle cx="10" cy="7" r="4"/><path d="M23 20v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-value"><%=contactCount%></div>
            <div class="kpi-label">Contacts</div>
          </div>
        </div>
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--purple-soft);color:var(--purple);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 21V9l8-5 8 5v12"/><path d="M9 21v-6h6v6"/></svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-value"><%=accountCount%></div>
            <div class="kpi-label">Accounts</div>
          </div>
        </div>
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--orange-soft);color:var(--orange);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3 6 6 1-4.5 4.5L18 20l-6-3-6 3 1.5-6.5L3 9l6-1z"/></svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-value"><%=deals%></div>
            <div class="kpi-label">Open Deals</div>
          </div>
        </div>

        <!-- ===== KPI ROW 2 ===== -->
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--teal-soft);color:var(--teal);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 9h8M8 13h5"/></svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-value"><%=risedQuotes%></div>
            <div class="kpi-label">Quotations Raised</div>
          </div>
        </div>
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--green-soft);color:var(--green);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-value"><%=approvedQuotes%></div>
            <div class="kpi-label">Approved Quotations</div>
          </div>
        </div>
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--blue-soft);color:var(--blue-dark);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8l-9-5-9 5 9 5 9-5z"/><path d="M3 8v8l9 5 9-5V8"/></svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-value"><%=rentalPurchase%></div>
            <div class="kpi-label">Rental Purchase Orders</div>
          </div>
        </div>
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--red-soft);color:var(--red);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
          </div>
		  <%
		  		pendingQuotes = Quotation[Status != "Approved"].count();
			%>
          <div class="kpi-text">
            <div class="kpi-value"><%=pendingQuotes%></div>
            <div class="kpi-label">Pending Quotations</div>
          </div>
        </div>

        <!-- ===== PIPELINE ACTIVITY CHART ===== -->
        <div class="widget col-8">
          <div class="widget-head">
            <div class="widget-head-left">
              <div class="widget-icon" style="background:var(--blue-soft);color:var(--blue);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19h16"/><rect x="6" y="10" width="3" height="7"/><rect x="11" y="6" width="3" height="11"/><rect x="16" y="13" width="3" height="4"/></svg>
              </div>
              <div>
                <div class="widget-title">Pipeline Activity</div>
                <div class="widget-subtitle">Record counts across the pipeline</div>
              </div>
            </div>
            <select class="period"><option>Last 30 Days</option></select>
          </div>
          <div class="divider"></div>
          <div class="trend-chart">
            <div class="trend-col">
              <div class="trend-val"><%=leadCount%></div>
              <div class="trend-bar-wrap"><div class="trend-bar" style="height:86px;background:var(--blue);"></div></div>
              <div class="trend-label">Leads</div>
            </div>
            <div class="trend-col">
              <div class="trend-val"><%=contactCount%></div>
              <div class="trend-bar-wrap"><div class="trend-bar" style="height:150px;background:var(--indigo);"></div></div>
              <div class="trend-label">Contacts</div>
            </div>
            <div class="trend-col">
              <div class="trend-val"><%=accountCount%></div>
              <div class="trend-bar-wrap"><div class="trend-bar" style="height:64px;background:var(--purple);"></div></div>
              <div class="trend-label">Accounts</div>
            </div>
            <div class="trend-col">
              <div class="trend-val"><%=deals%></div>
              <div class="trend-bar-wrap"><div class="trend-bar" style="height:54px;background:var(--orange);"></div></div>
              <div class="trend-label">Deals</div>
            </div>
            <div class="trend-col">
              <div class="trend-val"><%=risedQuotes%></div>
              <div class="trend-bar-wrap"><div class="trend-bar" style="height:46px;background:var(--teal);"></div></div>
              <div class="trend-label">Raised</div>
            </div>
            <div class="trend-col">
              <div class="trend-val"><%=approvedQuotes%></div>
              <div class="trend-bar-wrap"><div class="trend-bar" style="height:32px;background:var(--green);"></div></div>
              <div class="trend-label">Approved</div>
            </div>
            <div class="trend-col">
              <div class="trend-val"><%=rentalPurchase%></div>
              <div class="trend-bar-wrap"><div class="trend-bar" style="height:25px;background:var(--blue-dark);"></div></div>
              <div class="trend-label">Rental</div>
            </div>
          </div>
        </div>

        <!-- ===== QUICK INSIGHTS ===== -->
        <div class="widget col-4">
          <div class="widget-head">
            <div class="widget-head-left">
              <div class="widget-icon" style="background:var(--purple-soft);color:var(--purple);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h7l-1 8 10-12h-7z"/></svg>
              </div>
              <div>
                <div class="widget-title">Quick Insights</div>
                <div class="widget-subtitle">Conversion &amp; approval health</div>
              </div>
            </div>
          </div>
          <div class="divider"></div>

		  <%
		  		convert_to_leads = All_Enquiries[Enquiry_Status == "Qualified"].count();
				pending_quotes = risedQuotes - approvedQuotes;
				%>
          <div class="insight-block">
            <div class="insight-top"><span class="l">Lead → Deal Conversion</span><span class="v"><%=convert_to_leads%></span></div>
            <div class="progress-big"><div class="progress-big-fill" style="width:62.5%;background:linear-gradient(90deg,var(--blue),var(--teal));"></div></div>
            <div class="insight-note"><%=convert_to_leads%> deals from <%=leadCount%> leads this period</div>
          </div>

          <div class="insight-block">
            <div class="insight-top"><span class="l">Quotation Approval Rate</span><span class="v"><%=risedQuotes%></span></div>
            <div class="progress-big"><div class="progress-big-fill" style="width:69.2%;background:linear-gradient(90deg,var(--orange),var(--green));"></div></div>
            <div class="insight-note"><%=approvedQuotes%> approved of  <%=risedQuotes%> raised · <%=pending_quotes%> pending</div>
          </div>
        </div>

        <!-- ===== CONVERSION SUMMARY TABLE ===== -->
        <div class="widget col-12">
          <div class="widget-head">
            <div class="widget-head-left">
              <div class="widget-icon" style="background:var(--teal-soft);color:var(--teal);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
              </div>
              <div>
                <div class="widget-title">Conversion Summary</div>
                <div class="widget-subtitle">Stage-wise record totals</div>
              </div>
            </div>
            <div class="kebab"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/></svg></div>
          </div>
          <div class="divider"></div>
          <table class="data-table">
            <thead><tr><th>Stage Name</th><th>Status</th><th class="num">Total Count</th></tr></thead>
            <tbody>
              <tr>
                <td class="stage-name">
                  <div class="stage-icon" style="background:var(--blue);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 5h16l-6 8v6l-4 2v-8z"/></svg></div>
                  Leads Created
                </td>
                <td><span class="badge" style="background:var(--green-soft);color:var(--green);">Active</span></td>
                <td class="value"><%=leadCount%></td>
              </tr>
              <tr>
                <td class="stage-name">
                  <div class="stage-icon" style="background:var(--orange);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg></div>
                  Open Deals
                </td>
                <td><span class="badge" style="background:var(--blue-soft);color:var(--blue);">In Progress</span></td>
                <td class="value"><%=deals%></td>
              </tr>
              <tr>
                <td class="stage-name">
                  <div class="stage-icon" style="background:var(--green);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg></div>
                  Approved Quotations
                </td>
                <td><span class="badge" style="background:var(--orange-soft);color:var(--orange);">Verified</span></td>
                <td class="value"><%=approvedQuotes%></td>
              </tr>
              <tr>
                <td class="stage-name">
                  <div class="stage-icon" style="background:var(--blue-dark);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8l-9-5-9 5 9 5 9-5z"/><path d="M3 8v8l9 5 9-5V8"/></svg></div>
                  Rental Purchase Orders
                </td>
                <td><span class="badge" style="background:var(--green-soft);color:var(--green);">Completed</span></td>
                <td class="value"><%=rentalPurchase%></td>
              </tr>
            </tbody>
          </table>
