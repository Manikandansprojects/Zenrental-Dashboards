              </div>
              <div>
                <div class="widget-title">Lead Funnel</div>
                <div class="widget-subtitle">New Lead → Closed</div>
              </div>
            </div>
            <div class="kebab"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/></svg></div>
          </div>
          <div class="divider"></div>
<%
	newLeadCount = All_Enquiries[Enquiry_Status == "New"].count();
	convertedLeadCount = All_Enquiries[Enquiry_Status == "Qualified"].count();
	newDealCount = Bookings[Booking_Stage == "Qualification"].count();
	newQuoteCount = Quotation[Status == "Pending"].count();
	closedDealCount = Bookings[Booking_Stage == "Closed Won"].count();
	%>
<div class="funnel-row">
            <span class="funnel-label">New Lead</span>
            <div class="funnel-track"><div class="funnel-fill" style="width:100%;background:var(--blue);"><span>100%</span></div></div>
            <span class="funnel-count"><%=newLeadCount%></span>
          </div>
          <div class="funnel-row">
            <span class="funnel-label">Converted</span>
            <div class="funnel-track"><div class="funnel-fill" style="width:67%;background:var(--teal);"><span>67%</span></div></div>
            <span class="funnel-count"><%=convertedLeadCount%></span>
          </div>
          <div class="funnel-row">
            <span class="funnel-label">Deals</span>
            <div class="funnel-track"><div class="funnel-fill" style="width:50%;background:var(--orange);"><span>50%</span></div></div>
            <span class="funnel-count"><%=newDealCount%></span>
          </div>
          <div class="funnel-row">
            <span class="funnel-label">Quotation</span>
            <div class="funnel-track"><div class="funnel-fill" style="width:38%;background:var(--purple);"><span>38%</span></div></div>
            <span class="funnel-count"><%=newQuoteCount%></span>
          </div>
          <div class="funnel-row">
            <span class="funnel-label">Closed ✓</span>
            <div class="funnel-track"><div class="funnel-fill" style="width:25%;background:var(--green);"><span>25%</span></div></div>
            <span class="funnel-count"><%=closedDealCount%></span>
          </div>
        </div>

        <!-- ===== INVENTORY OVERVIEW ===== -->
        <div class="widget col-4">
          <div class="widget-head">
            <div class="widget-head-left">
              <div class="widget-icon" style="background:var(--blue-soft);color:var(--blue);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8l-9-5-9 5 9 5 9-5z"/><path d="M3 8v8l9 5 9-5V8"/></svg>
              </div>
              <div>
                <div class="widget-title">Inventory Overview</div>
                <div class="widget-subtitle">Stock status</div>
              </div>
            </div>
            <div class="kebab"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/></svg></div>
          </div>
          <div class="divider"></div>
          <div class="donut-wrap">
            <div class="donut">
              <div class="donut-center"><span class="n"><%=allQuanitityPieChart%></span><span class="t">Total</span></div>
            </div>
            <div class="legend">
              <div class="legend-row"><span class="legend-key"><span class="legend-swatch" style="background:var(--teal);"></span>Available</span><span class="legend-val"><%=available_percent%></span></div>
              <div class="legend-row"><span class="legend-key"><span class="legend-swatch" style="background:var(--blue);"></span>Booked</span><span class="legend-val"><%=booked_count%></span></div>
              <div class="legend-row"><span class="legend-key"><span class="legend-swatch" style="background:var(--red);"></span>Damaged</span><span class="legend-val"><%=damaged_count%></span></div>
              <div class="legend-row"><span class="legend-key"><span class="legend-swatch" style="background:var(--grey);"></span>Missing</span><span class="legend-val muted"><%=missing_quantity%></span></div>
            </div>
          </div>
        </div>
<%
	dispachToday = Dispatch_Management[Dispatch_Date == zoho.currenttime].count();
	setupToday = Setup_Installation[Set_up_Date_Time == zoho.currentdate].count();
	openSO = Sales_order[Status == "Pending"].count();
	itemsMarkedDamaged = Inventory[Damaged_Quantity != 0 && Damaged_Quantity != null].count();
	%>
<!-- ===== SALES ORDER OVERVIEW ===== -->
        <div class="widget col-4">
          <div class="widget-head">
            <div class="widget-head-left">
              <div class="widget-icon" style="background:var(--purple-soft);color:var(--purple);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
              </div>
              <div>
                <div class="widget-title">Sales Order Overview</div>
                <div class="widget-subtitle">Order pipeline</div>
              </div>
            </div>
            <div class="kebab"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/></svg></div>
          </div>
          <div class="divider"></div>
          <div class="bar-item">
            <div class="bar-item-top"><span class="name">Open</span><span class="val"><%=openSO%></span></div>
            <div class="bar-track"><div class="bar-fill" style="width:100%;background:var(--purple);"></div></div>
          </div>
          <div class="bar-item">
            <div class="bar-item-top"><span class="name">Dispatch</span><span class="val"><%=dispachToday%></span></div>
            <div class="bar-track"><div class="bar-fill" style="width:40%;background:var(--purple);opacity:.7;"></div></div>
          </div>
          <div class="bar-item">
            <div class="bar-item-top"><span class="name">Setup</span><span class="val"><%=setupToday%></span></div>
            <div class="bar-track"><div class="bar-fill" style="width:20%;background:var(--purple);opacity:.5;"></div></div>
          </div>
        </div>

        <!-- ===== RETURN & DAMAGE ===== -->
        <div class="widget col-4">
          <div class="widget-head">
            <div class="widget-head-left">
              <div class="widget-icon" style="background:var(--red-soft);color:var(--red);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 109-9 9.75 9.75 0 00-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
              </div>
              <div>
                <div class="widget-title">Return &amp; Damage</div>
                <div class="widget-subtitle">Reconciliation</div>
              </div>
            </div>
            <div class="kebab"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/></svg></div>
          </div>
          <div class="divider"></div>
          <div class="bar-item">
            <div class="bar-item-top"><span class="name">Returned</span><span class="val"><%=itemsReturned%></span></div>
            <div class="bar-track"><div class="bar-fill" style="width:100%;background:var(--teal);"></div></div>
          </div>
          <div class="bar-item">
            <div class="bar-item-top"><span class="name">Damaged</span><span class="val"><%=itemsMarkedDamaged%></span></div>
            <div class="bar-track"><div class="bar-fill" style="width:29%;background:var(--red);"></div></div>
          </div>
        </div>

        <!-- ===== EVENT BOOKINGS ===== -->
        <div class="widget col-8">
          <div class="widget-head">
            <div class="widget-head-left">
              <div class="widget-icon" style="background:var(--purple-soft);color:var(--purple);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
              </div>
              <div>
                <div class="widget-title">Event Bookings</div>
                <div class="widget-subtitle">By event type</div>
              </div>
            </div>
<%
	quoteEventscounts = Quotation[Event_Name != null && Event_Name != ""].count();
	%>
<span class="badge" style="background:var(--purple-soft);color:var(--purple);"><%=quoteEventscounts%>Total</span>
          </div>
          <div class="divider"></div>
          <table class="data-table">
            <thead><tr><th>Event Type</th><th>Share</th><th class="num">Qty</th></tr></thead>
            <tbody>
<%
	quoteEvents = Quotation[Event_Name != null && Event_Name != ""];
	eventCountMap = Map();
	for each  qut_i in quoteEvents
	{
		event = qut_i.Event_Name;
		if(eventCountMap.contains(event))
		{
			eventCountMap.put(event,eventCountMap.get(event) + 1);
		}
		else
		{
			eventCountMap.put(event,1);
		}
	}
	for each  eventName_i in eventCountMap.keys()
	{
		count = eventCountMap.get(eventName_i);
		%>
<tr>
                                    <td><i class="bi bi-star-fill me-2" style="color: #f57c1f; font-size: 11px;"></i><%=eventName_i%></td>
                                    <td class="text-end"><%=count%></td>
                                </tr>
<%
	}
	%>
</tbody>

          </table>
        </div>

        <!-- ===== DISPATCH & SETUP + BILLING ===== -->
        <div class="widget col-4">
          <div class="widget-head">
            <div class="widget-head-left">
              <div class="widget-icon" style="background:var(--orange-soft);color:var(--orange);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="7" width="15" height="10" rx="1"/><path d="M16 10h4l3 3v4h-7z"/><circle cx="5.5" cy="19.5" r="1.5"/><circle cx="18.5" cy="19.5" r="1.5"/></svg>
              </div>
              <div>
                <div class="widget-title">Dispatch &amp; Setup</div>
                <div class="widget-subtitle">Field operations</div>
              </div>
            </div>
            <div class="kebab"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/></svg></div>
          </div>
          <div class="divider"></div>
          <div class="bar-item">
            <div class="bar-item-top"><span class="name">Dispatches</span><span class="val"><%=dispatchCount%></span></div>
            <div class="bar-track"><div class="bar-fill" style="width:100%;background:var(--orange);"></div></div>
          </div>
          <div class="bar-item">
            <div class="bar-item-top"><span class="name">Setup</span><span class="val"><%=setupCount%></span></div>
            <div class="bar-track"><div class="bar-fill" style="width:73%;background:var(--orange);opacity:.7;"></div></div>
          </div>

          <div class="divider" style="margin-top:18px;"></div>
          <div class="widget-head" style="margin-bottom:12px;">
            <div class="widget-head-left">
              <div class="widget-icon" style="background:var(--green-soft);color:var(--green);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
              </div>
              <div>
                <div class="widget-title">Billing &amp; Payments</div>
                <div class="widget-subtitle">Receivables</div>
              </div>
            </div>
          </div>
		  
          <div class="nodata-grid">
            <div class="nodata-tile"><div class="dash">—</div><div class="l">Unpaid</div></div>
            <div class="nodata-tile"><div class="dash">—</div><div class="l">Overdue</div></div>
            <div class="nodata-tile"><div class="dash">—</div><div class="l">Partial</div></div>
          </div>
          <div class="nodata-foot">No billing records synced for this cycle.</div>
        </div>
		
      </div>
    </div>
  </div>
</div>
</body>
</html>
<%

}%>
