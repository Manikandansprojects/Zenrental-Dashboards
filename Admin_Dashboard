<%{
	%>
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --blue:#1E88E5;
    --blue-dark:#1565C0;
    --blue-soft:#E8F2FD;
    --teal:#089BAB;
    --teal-soft:#E1F3F5;
    --green:#2FA35A;
    --green-soft:#E5F5EA;
    --orange:#F0932B;
    --orange-soft:#FDEEDF;
    --red:#E5504A;
    --red-soft:#FCE7E6;
    --purple:#7C5CBF;
    --purple-soft:#EFE9FA;
    --grey:#B0B7C0;
    --grey-soft:#EEF0F3;

    --sidebar-w:64px;
    --bg:#F4F6F8;
    --surface:#FFFFFF;
    --ink:#23272E;
    --ink-soft:#6B7280;
    --ink-faint:#9AA1AC;
    --line:#E4E7EB;
    --radius:8px;
    --shadow:0 1px 3px rgba(16,24,40,0.06), 0 1px 2px rgba(16,24,40,0.04);
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    font-family:'Inter','Roboto',Arial,sans-serif;
    background:var(--bg);
    color:var(--ink);
    font-size:14px;
  }
  a{text-decoration:none;color:inherit;}

  /* ===================== LAYOUT ===================== */
  .app{
    display:flex;
    min-height:100vh;
  }

  /* ---------- SIDEBAR ---------- */
  .sidebar{
    width:var(--sidebar-w);
    background:#FFFFFF;
    border-right:1px solid var(--line);
    display:flex;
    flex-direction:column;
    align-items:center;
    padding:16px 0;
    flex:none;
  }
  .sidebar .logo{
    width:34px;height:34px;
    border-radius:8px;
    background:var(--teal);
    color:#fff;
    display:flex;align-items:center;justify-content:center;
    font-family:'Inter',sans-serif;
    font-weight:700;
    font-size:15px;
    margin-bottom:28px;
  }
  .sidebar nav{
    display:flex;
    flex-direction:column;
    gap:6px;
    width:100%;
    align-items:center;
  }
  .sidebar .nav-item{
    width:40px;height:40px;
    border-radius:8px;
    display:flex;align-items:center;justify-content:center;
    color:var(--ink-faint);
    cursor:pointer;
  }
  .sidebar .nav-item svg{width:19px;height:19px;}
  .sidebar .nav-item.active{
    background:var(--teal-soft);
    color:var(--teal);
  }
  .sidebar .nav-item:hover:not(.active){background:var(--grey-soft);color:var(--ink-soft);}
  .sidebar .nav-spacer{flex:1;}
  .sidebar .nav-bottom{margin-top:auto;display:flex;flex-direction:column;gap:6px;align-items:center;}

  /* ---------- MAIN ---------- */
  .main{
    flex:1;
    min-width:0;
    display:flex;
    flex-direction:column;
  }

  /* ---------- TOPBAR ---------- */
  .topbar{
    background:#fff;
    border-bottom:1px solid var(--line);
    padding:0 28px;
    height:60px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:10px;
  }
  .topbar-title{
    display:flex;
    align-items:center;
    gap:10px;
  }
  .topbar-title h1{
    font-size:17px;
    font-weight:700;
    margin:0;
    color:var(--ink);
    font-family:'Inter',sans-serif;
  }
  .breadcrumb{
    font-size:12.5px;
    color:var(--ink-faint);
    font-weight:500;
  }
  .topbar-actions{
    display:flex;
    align-items:center;
    gap:10px;
  }
  .btn{
    display:flex;
    align-items:center;
    gap:6px;
    font-size:13px;
    font-weight:600;
    padding:7px 12px;
    border-radius:6px;
    border:1px solid var(--line);
    background:#fff;
    color:var(--ink-soft);
    cursor:pointer;
  }
  .btn:hover{background:var(--grey-soft);}
  .btn.primary{
    background:var(--teal);
    border-color:var(--teal);
    color:#fff;
  }
  .btn.primary:hover{background:#078391;}
  .btn svg{width:14px;height:14px;}
  .avatar{
    width:32px;height:32px;
    border-radius:50%;
    background:var(--purple);
    color:#fff;
    font-size:13px;
    font-weight:700;
    display:flex;align-items:center;justify-content:center;
  }
  .live-badge{
    display:flex;align-items:center;gap:6px;
    font-size:11.5px;font-weight:700;
    color:var(--green);
    background:var(--green-soft);
    padding:5px 10px 5px 8px;
    border-radius:999px;
    letter-spacing:.03em;
  }
  .live-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 1.8s infinite;}
  @keyframes pulse{
    0%{box-shadow:0 0 0 0 rgba(47,163,90,.5);}
    70%{box-shadow:0 0 0 6px rgba(47,163,90,0);}
    100%{box-shadow:0 0 0 0 rgba(47,163,90,0);}
  }

  /* ---------- CONTENT ---------- */
  .content{
    padding:24px 28px 40px;
    max-width:1480px;
    width:100%;
    margin:0 auto;
  }

  .grid{
    display:grid;
    grid-template-columns:repeat(12,1fr);
    gap:18px;
  }
  .col-12{grid-column:span 12;}
  .col-8{grid-column:span 8;}
  .col-7{grid-column:span 7;}
  .col-6{grid-column:span 6;}
  .col-5{grid-column:span 5;}
  .col-4{grid-column:span 4;}
  .col-3{grid-column:span 3;}

  /* ---------- KPI CARDS ---------- */
  .kpi-card{
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:var(--radius);
    box-shadow:var(--shadow);
    padding:16px 18px;
    display:flex;
    align-items:center;
    gap:14px;
  }
  .kpi-icon{
    width:42px;height:42px;
    border-radius:8px;
    display:flex;align-items:center;justify-content:center;
    flex:none;
  }
  .kpi-icon svg{width:20px;height:20px;}
  .kpi-text{min-width:0;}
  .kpi-value{
    font-size:24px;
    font-weight:700;
    line-height:1.1;
    color:var(--ink);
    font-family:'Inter',sans-serif;
  }
  .kpi-label{
    font-size:12.5px;
    color:var(--ink-soft);
    font-weight:500;
    margin-top:2px;
    white-space:nowrap;
  }

  /* ---------- WIDGET CARD ---------- */
  .widget{
    background:var(--surface);
    border:1px solid var(--line);
    border-radius:var(--radius);
    box-shadow:var(--shadow);
    padding:18px 20px 20px;
  }
  .widget-head{
    display:flex;
    align-items:center;
    justify-content:space-between;
    margin-bottom:16px;
  }
  .widget-head-left{display:flex;align-items:center;gap:9px;}
  .widget-icon{
    width:28px;height:28px;
    border-radius:6px;
    display:flex;align-items:center;justify-content:center;
    flex:none;
  }
  .widget-icon svg{width:15px;height:15px;}
  .widget-title{
    font-size:14.5px;
    font-weight:700;
    color:var(--ink);
  }
  .widget-subtitle{
    font-size:11.5px;
    color:var(--ink-faint);
    font-weight:500;
    margin-top:1px;
  }
  .kebab{
    color:var(--ink-faint);
    cursor:pointer;
    padding:4px;
  }
  .kebab svg{width:16px;height:16px;display:block;}

  .divider{
    height:1px;
    background:var(--line);
    margin:0 0 16px;
  }

  /* ---------- FOLLOW-UP MINI STATS ---------- */
  .mini-stats{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:10px;
  }
  .mini-stat{
    background:var(--grey-soft);
    border-radius:7px;
    padding:12px 14px;
  }
  .mini-stat .v{font-size:20px;font-weight:700;color:var(--ink);}
  .mini-stat .v.alert{color:var(--red);}
  .mini-stat .l{font-size:11.5px;color:var(--ink-soft);font-weight:500;margin-top:2px;}

  /* ---------- FUNNEL ---------- */
  .funnel-row{
    display:grid;
    grid-template-columns:88px 1fr 34px;
    align-items:center;
    gap:10px;
    margin-bottom:11px;
  }
  .funnel-row:last-child{margin-bottom:0;}
  .funnel-label{font-size:12.5px;font-weight:600;color:var(--ink-soft);text-align:right;}
  .funnel-track{height:22px;border-radius:4px;background:var(--grey-soft);overflow:hidden;}
  .funnel-fill{
    height:100%;
    border-radius:4px;
    display:flex;align-items:center;justify-content:flex-end;
    padding-right:8px;
  }
  .funnel-fill span{font-size:10.5px;color:#fff;font-weight:700;}
  .funnel-count{font-size:13.5px;font-weight:700;color:var(--ink);}

  /* ---------- BAR LIST ---------- */
  .bar-item{margin-bottom:13px;}
  .bar-item:last-child{margin-bottom:0;}
  .bar-item-top{display:flex;justify-content:space-between;margin-bottom:6px;}
  .bar-item-top .name{font-size:13px;font-weight:600;color:var(--ink);}
  .bar-item-top .val{font-size:13px;font-weight:700;color:var(--ink);}
  .bar-track{height:7px;background:var(--grey-soft);border-radius:4px;overflow:hidden;}
  .bar-fill{height:100%;border-radius:4px;}

  /* ---------- DONUT ---------- */
  .donut-wrap{display:flex;align-items:center;gap:22px;}
  .donut{
    width:112px;height:112px;border-radius:50%;flex:none;position:relative;
    background:conic-gradient(
      var(--teal) 0% 55%,
      var(--blue) 55% 77.9%,
      var(--red) 77.9% 91.9%,
      var(--grey) 91.9% 100%
    );
  }
  .donut::after{content:'';position:absolute;inset:18px;background:#fff;border-radius:50%;}
  .donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:1;}
  .donut-center .n{font-size:19px;font-weight:700;color:var(--ink);}
  .donut-center .t{font-size:9.5px;color:var(--ink-faint);font-weight:600;text-transform:uppercase;letter-spacing:.04em;}
  .legend{flex:1;display:flex;flex-direction:column;gap:9px;}
  .legend-row{display:flex;align-items:center;justify-content:space-between;font-size:13px;}
  .legend-key{display:flex;align-items:center;gap:8px;color:var(--ink-soft);font-weight:500;}
  .legend-swatch{width:9px;height:9px;border-radius:2px;flex:none;}
  .legend-val{font-weight:700;color:var(--ink);}
  .legend-val.muted{color:var(--ink-faint);}

  /* ---------- TABLE ---------- */
  table.data-table{width:100%;border-collapse:collapse;}
  table.data-table thead th{
    text-align:left;
    font-size:11.5px;
    font-weight:700;
    color:var(--ink-faint);
    text-transform:uppercase;
    letter-spacing:.03em;
    padding:0 0 10px;
    border-bottom:1px solid var(--line);
  }
  table.data-table thead th.num{text-align:right;}
  table.data-table tbody td{
    padding:11px 0;
    border-bottom:1px solid var(--line);
    font-size:13.5px;
    color:var(--ink);
  }
  table.data-table tbody tr:last-child td{border-bottom:none;}
  table.data-table td.name{font-weight:600;width:34%;}
  table.data-table td.bar-cell{width:44%;}
  table.data-table td.qty{text-align:right;font-weight:700;width:22%;}
  .row-track{height:6px;background:var(--grey-soft);border-radius:3px;overflow:hidden;}
  .row-fill{height:100%;background:var(--purple);border-radius:3px;}

  /* ---------- NO DATA ---------- */
  .nodata-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
  .nodata-tile{
    background:var(--grey-soft);
    border:1px dashed #CBD1D9;
    border-radius:7px;
    padding:14px 10px;
    text-align:center;
  }
  .nodata-tile .dash{font-size:20px;font-weight:700;color:var(--ink-faint);}
  .nodata-tile .l{font-size:11px;color:var(--ink-soft);font-weight:500;margin-top:5px;}
  .nodata-foot{margin-top:12px;font-size:11.5px;color:var(--ink-faint);}

  .badge{
    font-size:11px;font-weight:700;
    padding:4px 10px;border-radius:5px;
  }

  @media (max-width:1100px){
    .col-8,.col-7,.col-6,.col-5,.col-4,.col-3{grid-column:span 12;}
  }
  @media (max-width:640px){
    .content{padding:18px;}
    .mini-stats{grid-template-columns:1fr 1fr;}
    .nodata-grid{grid-template-columns:1fr;}
    .donut-wrap{flex-direction:column;align-items:flex-start;}
  }
</style>
</head>
<body>
<div class="app">


  <!-- ===================== MAIN ===================== -->
  <div class="main">

    <!-- TOPBAR -->
    <header class="topbar">
      <div class="topbar-title">
        <div>
          <h1>Admin Dashboard</h1>
         
        </div>
      </div>
      <div class="topbar-actions">
        
        <button class="btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          This Month
        </button>

      </div>
    </header>
<%
	totalQuantity = 0;
	inventoryAvailable = Inventory[Available_Quantity != 0];
	totalQuantity = 0;
	for each  item in inventoryAvailable
	{
		totalQuantity = totalQuantity + item.Available_Quantity;
	}
	inventoryBooked = Inventory[Rented_Quantity != 0];
	totalRented = 0;
	for each  i in inventoryBooked
	{
		totalRented = totalRented + i.Rented_Quantity;
	}
	totalDamaged = 0;
	totalMissing = 0;
	inventoryDamaged = Inventory[Damaged_Quantity != 0];
	for each  i in inventoryDamaged
	{
		totalDamaged = totalDamaged + i.Damaged_Quantity;
	}
	allQuanitityPieChart = totalQuantity + totalDamaged + totalMissing;
	if(allQuanitityPieChart != 0)
	{
		available_percent = (totalQuantity * 100.0) / allQuanitityPieChart;
		booked_percent = (totalRented * 100.0) / allQuanitityPieChart;
		damaged_percent = (totalDamaged * 100.0) / allQuanitityPieChart;
		booked_count = totalRented;
		damaged_count = totalDamaged;
	}
	else
	{
		available_percent = 0;
		booked_percent = 0;
		damaged_percent = 0;
	}
	available_percent = round(available_percent,1);
	booked_percent = round(booked_percent,1);
	damaged_percent = round(damaged_percent,1);
	startDateParams = input.sDate;
	endDateParams = input.eDate;
	today = zoho.currentdate;
	startOfMonth = today.toDate().toStartOfMonth();
	if(input.sDate != null)
	{
		today = endDateParams;
		startOfMonth = startDateParams;
		irukka = "Params Passed";
		leadCount = All_Enquiries[Added_Time >= startOfMonth && Added_Time <= today || Added_Time == today].count();
		accountCount = Account[Added_Time >= startOfMonth && Added_Time <= today || Added_Time == today].count();
		contactCount = Contact[Added_Time >= startOfMonth && Added_Time <= today || Added_Time == today].count();
		deals = Bookings[Added_Time >= startOfMonth && Added_Time <= today || Added_Time == today].count();
		approvedQuotes = Quotation[Status == "Approved" && Added_Time >= startOfMonth && Added_Time <= today || Added_Time == today].count();
		invoicedCount = Invoice[Added_Time >= startOfMonth && Added_Time <= today || Added_Time == today].count();
		itemsReturned = Return_Inward_Process[Added_Time >= startOfMonth && Added_Time <= today || Added_Time == today].count();
		dispatchCount = Dispatch_Management[Dispatch_Date >= startOfMonth && Dispatch_Date <= today || Dispatch_Date == today].count();
		setupCount = Setup_Installation[Set_up_Date_Time >= startOfMonth && Set_up_Date_Time <= today || Set_up_Date_Time == today].count();
	}
	else
	{
		today = zoho.currentdate;
		startOfMonth = today.toDate().toStartOfMonth();
		irukka = "No Params";
		leadCount = All_Enquiries[ID != null].count();
		accountCount = Account[ID != null].count();
		contactCount = Contact[ID != null].count();
		deals = Bookings[ID != null].count();
		approvedQuotes = Quotation[Status == "Approved"].count();
		invoicedCount = Invoice[ID != null].count();
		itemsReturned = Return_Inward_Process[ID != null].count();
		dispatchCount = Dispatch_Management[ID != null].count();
		setupCount = Setup_Installation[ID != null].count();
		openTasks = Task[Task_Status == "Not Started"].count();
		overdueTasks = Task[Task_Status == "Overdue"].count();
		scheduledCalls = Call[Call_Action == "Schedule a Call"].count();
		scheduledMeeting = Meetings[Start_Date_Time > zoho.currenttime].count();
		totalQuantity = 0;
		inventoryAvailable = Inventory[Available_Quantity != 0];
		missing_quantity = 0;
		missing_Qty = Inventory[Missing_Qty != 0];
		totalQuantity = 0;
		for each  item in inventoryAvailable
		{
			totalQuantity = totalQuantity + item.Available_Quantity;
			missing_quantity = missing_quantity + item.Missing_Qty;
		}
	}
	%>
<!-- CONTENT -->
    <div class="content">
      <div class="grid">

        <!-- ===== KPI ROW ===== -->
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--teal-soft);color:var(--teal);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="3.5"/><path d="M5 20c0-3.5 3-6 7-6s7 2.5 7 6"/></svg>
          </div>
		  
          <div class="kpi-text">
            <div class="kpi-value"><%=leadCount%></div>
            <div class="kpi-label">Leads</div>
          </div>
        </div>
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--blue-soft);color:var(--blue);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 21V9l8-5 8 5v12"/><path d="M9 21v-6h6v6"/></svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-value"><%=accountCount%></div>
            <div class="kpi-label">Accounts</div>
          </div>
        </div>
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--purple-soft);color:var(--purple);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 20v-2a4 4 0 00-4-4H7a4 4 0 00-4 4v2"/><circle cx="10" cy="7" r="4"/><path d="M23 20v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-value"><%=contactCount%></div>
            <div class="kpi-label">Contacts</div>
          </div>
        </div>
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--orange-soft);color:var(--orange);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3 6 6 1-4.5 4.5L18 20l-6-3-6 3 1.5-6.5L3 9l6-1z"/></svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-value"><%=deals%></div>
            <div class="kpi-label">Deals</div>
          </div>
        </div>
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--green-soft);color:var(--green);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-value"><%=approvedQuotes%></div>
            <div class="kpi-label">Approved</div>
          </div>
        </div>
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--teal-soft);color:var(--teal);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 9h8M8 13h5"/></svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-value"><%=invoicedCount%></div>
            <div class="kpi-label">Invoiced</div>
          </div>
        </div>
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--red-soft);color:var(--red);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><path d="M12 9v4M12 17h.01"/></svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-value"><%=overdueTasks%></div>
            <div class="kpi-label">Overdue Tasks</div>
          </div>
        </div>
        <div class="kpi-card col-3">
          <div class="kpi-icon" style="background:var(--blue-soft);color:var(--blue);">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8l-9-5-9 5 9 5 9-5z"/><path d="M3 8v8l9 5 9-5V8"/></svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-value"><%=totalQuantity%></div>
            <div class="kpi-label">Inventory Items</div>
          </div>
        </div>

        <!-- ===== FOLLOW-UP ACTIVITIES ===== -->
        <div class="widget col-3">
          <div class="widget-head">
            <div class="widget-head-left">
              <div class="widget-icon" style="background:var(--orange-soft);color:var(--orange);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
              </div>
              <div>
                <div class="widget-title">Follow-up Activities</div>
                <div class="widget-subtitle">Task queue</div>
              </div>
            </div>
            <div class="kebab"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/></svg></div>
          </div>
<%
	openTasks = Task[Task_Status == "Not Started"].count();
	overdueTasks = Task[Task_Status == "Overdue"].count();
