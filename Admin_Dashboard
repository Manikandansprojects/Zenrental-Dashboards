	scheduledMeeting = Meetings[Start_Date_Time > zoho.currenttime].count();
	%>
<div class="divider"></div>
          <div class="mini-stats">
            <div class="mini-stat"><div class="v"><%=openTasks%></div><div class="l">Open Tasks</div></div>
            <div class="mini-stat"><div class="v alert"><%=overdueTasks%></div><div class="l">Overdue</div></div>
            <div class="mini-stat"><div class="v"><%=scheduledCalls%></div><div class="l">Calls</div></div>
            <div class="mini-stat"><div class="v"><%=scheduledMeeting%></div><div class="l">Meetings</div></div>
          </div>
        </div>

